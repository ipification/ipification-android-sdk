<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ip_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Top bar with back button -->
    <LinearLayout
        android:id="@+id/ip_topbar"
        style="@style/IPWebViewTopBar">

        <ImageButton
            android:id="@+id/ip_btn_back"
            style="@style/IPWebViewBackButton"
            android:src="@drawable/ip_ic_back"
            android:contentDescription="Back" />

    </LinearLayout>

    <!-- Content area with WebView and overlay ProgressBar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/ip_webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/ip_progress"
            style="@android:style/Widget.DeviceDefault.Light.ProgressBar.Large"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
