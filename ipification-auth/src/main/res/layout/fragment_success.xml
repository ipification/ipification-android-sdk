<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    >

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintWidth_percent=".95"
        android:textColor="@color/text_color_adaptive"
        android:textSize="@dimen/size_text_30"
        android:layout_marginTop="@dimen/margin_60"
        android:textAlignment="center"
        app:layout_constraintBottom_toTopOf="@+id/ivIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Success Auth"
        android:gravity="center_horizontal" />

    <ImageView
        android:id="@+id/ivIcon"
        android:layout_width="78dp"
        android:layout_height="78dp"
        android:src="@drawable/ic_success"
        android:layout_marginTop="@dimen/margin_45"
        app:layout_constraintBottom_toTopOf="@+id/tvRedirectMessage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle"
        />

    <TextView
        android:id="@+id/tvRedirectMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintWidth_percent=".8"
        android:textColor="@color/text_color_adaptive"
        android:gravity="center"
        android:textSize="@dimen/size_text_small_16"
        android:layout_marginTop="@dimen/margin_45"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivIcon"
        tools:text="success auth" />

</androidx.constraintlayout.widget.ConstraintLayout>